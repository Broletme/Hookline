# ── Groq ──────────────────────────────────────────────────────────────────────
# Get your key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
# Use the "service_role" secret key (NOT the anon key) so the backend can
# write to the DB and upload to Storage without RLS restrictions.
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Storage ───────────────────────────────────────────────────────────────────
# Name of the Supabase Storage bucket that will hold cut clips.
# Create this bucket (public) in: Storage → New bucket → clips
SUPABASE_CLIPS_BUCKET=clips

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the FastAPI CORS middleware
CORS_ORIGINS=http://localhost:3000
